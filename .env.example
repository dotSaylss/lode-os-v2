# ── Mogul Agent — environment configuration ──────────────────────────────────
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
#
# Two ways to authenticate the Gemini models used by the ADK agents:
#
# Option A (recommended for the hackathon) — Vertex AI via Application Default
# Credentials. Run `gcloud auth application-default login` first, then set:
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=winning-startup-challenge
GOOGLE_CLOUD_LOCATION=us-central1

# Option B — Google AI Studio API key (simpler, no GCP project needed).
# Comment out the three Vertex lines above and uncomment the line below:
# GOOGLE_API_KEY=your-ai-studio-api-key

# ── Label / Catalog Ops agent (optional) ─────────────────────────────────────
# Compute runtime for the LabelAgent graph. Default is the in-process Runner
# inside FastAPI (zero extra setup). Set to "agent_engine" to wrap the same
# graph in Vertex AI Agent Engine (managed Agent Runtime); falls back to
# in-process if the managed SDK is unavailable.
# LABEL_AGENT_RUNTIME=in_process
#
# Model routing (Model Garden ready). Repoint either agent at any Vertex /
# Model Garden model without code changes. Defaults shown.
# LABEL_STRATEGIST_MODEL=gemini-2.5-pro
# LABEL_EXECUTION_MODEL=gemini-2.5-flash
